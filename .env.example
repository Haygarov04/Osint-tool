# --- Upstash Redis (основна база) ---
# Взимат се автоматично, когато добавиш Upstash storage към проекта във Vercel.
# За локален дев ги копирай тук от Upstash конзолата / Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Google Places (втори източник, по избор) ---
# Google Maps API ключ с включен "Places API". Само сървър, никога не се излага в UI.
# Ако е празно, приложението ползва само OSM (безплатно).
GOOGLE_MAPS_API_KEY=

# --- xAI (Grok) за AI персонализация на съобщения и анализи ---
# Вземи ключ от https://console.x.ai
# Използва се за генериране на персонализирани outreach съобщения.
XAI_API_KEY=xai-...

# --- Парола за сайта (задължително за production) ---
# Ако е празно, сайтът е отворен (удобно за локално тестване).
SITE_PASSWORD=твоята_тайна_парола

# --- По избор ---
# Алтернативен Overpass endpoint (по подразбиране overpass-api.de).
# OVERPASS_URL=https://overpass-api.de/api/interpreter
